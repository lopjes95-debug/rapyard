{
  "name": "rapyard",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf node_modules",
    "doctor": "turbo run doctor"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*",
    "infra"
  ],
  "devDependencies": {
    "turbo": "2.0.0",
    "typescript": "5.4.5",
    "rimraf": "5.0.5"
  }
}
