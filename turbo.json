{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^dev"]
    },

    "lint": {
      "outputs": []
    },

    "typecheck": {
      "outputs": []
    },

    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "build/**"
      ]
    },

    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },

    "clean": {
      "cache": false
    }
  }
}
