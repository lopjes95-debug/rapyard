{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "paths": {
      "@web/*": ["apps/web/*"],
      "@mobile/*": ["apps/mobile/*"],
      "@docs/*": ["apps/docs/*"],
      "@api/*": ["apps/api/*"],
      "@worker/*": ["apps/worker/*"],
      "@ui/*": ["packages/ui/*"],
      "@config/*": ["packages/config/*"],
      "@utils/*": ["packages/utils/*"]
    }
  }
}
