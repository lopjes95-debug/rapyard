{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "^preview\\.rapyard\\.club$"
        }
      ],
      "destination": "/"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "^apps\\.(?<app>[^\\.]+)\\.rapyard\\.club$"
        }
      ],
      "destination": "/apps/:app"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "^(?<tenant>[^\\.]+)\\.rapyard\\.club$"
        }
      ],
      "destination": "/tenant/:tenant"
    }
  ]
}
