{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm build",
  "framework": "vite",
  "outputDirectory": "apps/web/dist",

  "redirects": [
    {
      "source": "https://www.rapyard.club/:path*",
      "destination": "https://rapyard.club/:path*",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.rapyard.com/:path*"
    }
  ],

  "functions": {
    "api/**": {
      "runtime": "nodejs20",
      "memory": 1024,
      "maxDuration": 30
    }
  },

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
